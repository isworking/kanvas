#pragma once

#ifndef KVS_CONFIG_H
#define KVS_CONFIG_H

/*
 * Version information
 */

#define KVS_VERSION_MAJOR @PROJECT_VERSION_MAJOR @
#define KVS_VERSION_MINOR @PROJECT_VERSION_MINOR @
#define KVS_VERSION_PATCH @PROJECT_VERSION_PATCH @

#define KVS_VERSION              \
    ((KVS_VERSION_MAJOR << 16) | \
     (KVS_VERSION_MINOR << 8) |  \
     KVS_VERSION_PATCH)

#define KVS_VERSION_STRING "@PROJECT_VERSION@"

/*
 * Feature configuration
 */

#cmakedefine01 KVS_ENABLE_PNG

#endif